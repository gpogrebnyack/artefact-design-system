{
  "name": "artefact-design-system",
  "version": "0.16.1",
  "description": "Артефакт design system — Foundation/Primitives/Components/Sections on top of shadcn/ui + Radix, published as an installable package.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gpogrebnyack/artefact-design-system.git"
  },
  "files": [
    "dist",
    "/AGENTS.md",
    "context/DESIGN.md",
    "context/COMPONENTS.md",
    "scripts/postinstall.mjs"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build:js": "tsup",
    "build:css": "tailwindcss -i src/index.css -o dist/style.css --minify && mkdir -p dist/fonts && cp src/fonts/*.woff2 dist/fonts/",
    "build": "npm run lint:design && npm run check:context && npm run check:css-vars && npm run typecheck && npm run build:js && npm run build:css",
    "lint:design": "node scripts/lint-design-summary.mjs",
    "check:context": "node scripts/check-context-sync.mjs",
    "typecheck": "tsc --noEmit",
    "dev:css": "tailwindcss -i src/index.css -o dist/style.css --watch",
    "storybook": "storybook dev -p 6009 --no-open",
    "build-storybook": "storybook build",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.mjs",
    "generate:icons": "node scripts/generate-icon-catalog.mjs",
    "check:css-vars": "node scripts/check-css-vars.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint:design && npm run check:context && npm run check:css-vars && npm run typecheck"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react-is": "^19.2.7",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/design.md": "^0.3.0",
    "@phosphor-icons/core": "^2.1.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.3.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
